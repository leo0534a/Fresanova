# ============================================
# fresanova - Variables de Entorno
# ============================================

# SERVIDOR
PORT=5000
NODE_ENV=development

# BASE DE DATOS
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/fresanova?retryWrites=true&w=majority&appName=Cluster0

# JWT
JWT_SECRET=tu_jwt_secret_aqui
JWT_EXPIRES_IN=7d

# TWILIO WHATSAPP
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_VERIFY_TOKEN=fresanova_verify_token

# DEEPSEEK IA
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ADMIN
ADMIN_EMAIL=admin@fresanova.com
ADMIN_PASSWORD=Admin123*

# URLS
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# RENDER
RENDER_EXTERNAL_URL=

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# RATE LIMIT
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SESSION
SESSION_SECRET=fresanova_session_secret

# LOGS
LOG_LEVEL=debug

# ZONA HORARIA
TIMEZONE=America/Bogota

# NEGOCIO
BUSINESS_NAME=Fresanova
BUSINESS_CITY=Cartagena
DELIVERY_PRICE=10000
# DELIVERY_PRICE se usa como fallback si el barrio no está registrado en la BD
BUSINESS_OPEN_HOUR=08:00
BUSINESS_CLOSE_HOUR=20:00

# IMAGEN PARA TRANSFERENCIA (BRE-B)
TRANSFER_IMAGE_URL=
